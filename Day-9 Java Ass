1) Create a List of 5 float values and using a for loop check for condition and print only the 2nd element

package assign;
import java.util.ArrayList;
import java.util.List;

public class Collection_Loopass {
	
public static void main(String[] args) {
		List<Float> li = new ArrayList<>();//li ->list name
		li.add(25.5f);
		li.add(20.9f);
		li.add(40.2f);
		li.add(30.7f);
		li.add(37.5f);
		
		for (int i=0;i<li.size();i++) { // li.size -> total elements
		//Condition;
			if (i==1) {
				System.out.println("Second Value  : "+li.get(i));
		}	
	  }
	}
  }

